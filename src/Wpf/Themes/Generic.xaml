<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:v="clr-namespace:ADaxer.MvvmNav.Wpf.Views">

    <BooleanToVisibilityConverter x:Key="b2v" />

    <Style TargetType="{x:Type v:WpfDialog}">
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Title" Value="{Binding Title}" />
        <Setter Property="WindowStyle" Value="ToolWindow" />
        <Setter Property="ShowCommands" Value="true" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type v:WpfDialog}">
                    <DockPanel Background="{TemplateBinding Background}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" DockPanel.Dock="Bottom" Visibility="{TemplateBinding ShowCommands, Converter={StaticResource b2v}}">
                            <Button Content="Yes" IsDefault="True" x:Name="PART_OkButton"/>
                            <Button Content="No" IsCancel="True"/>
                        </StackPanel>
                        <ContentPresenter Content="{Binding}"/>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
