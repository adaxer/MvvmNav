<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:ADaxer.MvvmNav.Wpf.ViewModels"
                    xmlns:v="clr-namespace:ADaxer.MvvmNav.Wpf.Views">

    <BooleanToVisibilityConverter x:Key="b2v" />

    <DataTemplate DataType="{x:Type vm:MessageViewModel}">
        <v:MessageView/>
    </DataTemplate>

    <Style TargetType="{x:Type v:WpfDialog}">
        <Style.Resources>
            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="5"/>
                <Setter Property="MinWidth" Value="50"/>
            </Style>
        </Style.Resources>
        <Setter Property="SizeToContent" Value="WidthAndHeight" />
        <Setter Property="MaxWidth" Value="800"/>
        <Setter Property="MaxHeight" Value="450"/>
        <Setter Property="Background" Value="White" />
        <Setter Property="Title" Value="{Binding Title}" />
        <Setter Property="WindowStyle" Value="ToolWindow" />
        <Setter Property="ShowCommands" Value="true" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type v:WpfDialog}">
                    <DockPanel Background="{TemplateBinding Background}">
                        <Grid DockPanel.Dock="Bottom" Background="#ddd">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10" Visibility="{TemplateBinding ShowCommands, Converter={StaticResource b2v}}">
                                <Button Content="Yes" IsDefault="True" x:Name="PART_YesButton"/>
                                <Button Content="No" x:Name="PART_NoButton"/>
                                <Button Content="Cancel" IsCancel="True" x:Name="PART_CancelButton"/>
                            </StackPanel>
                        </Grid>
                        <ContentPresenter Content="{Binding}"/>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
